<Window x:Class="PhotoVault.Views.MainWindow"
        x:Name="mainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhotoVault.Views"
        xmlns:ctrl="clr-namespace:PhotoVault.Views.Controls"
        Title="PhotoVault" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen" Style="{StaticResource MainWindowStyle}"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvVis"/>
        <local:StringEqualsToVisibilityConverter x:Key="StrVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseDown" Panel.ZIndex="200">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="14,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" Margin="0,0,9,0"/>
                    <TextBlock Text="PhotoVault" Foreground="{StaticResource Text2Brush}" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#x2014;" Style="{StaticResource TbBtn}" Click="Min_Click"/>
                    <Button x:Name="maxBtn" Content="&#x25A1;" Style="{StaticResource TbBtn}" Click="Max_Click"/>
                    <Button Content="&#x2715;" Style="{StaticResource TbClose}" Click="Close_Click"/>
                </StackPanel>
                <Border/>
            </DockPanel>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,10,14,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,5"><TextBlock Text="Library" FontSize="10.5" Foreground="{StaticResource Text3Brush}"/><TextBlock Text="{Binding MediaCount, StringFormat='{}{0} items'}" FontSize="10.5" Foreground="{StaticResource Text3Brush}" DockPanel.Dock="Right" HorizontalAlignment="Right"/></DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}" Margin="0,0,7,0"/><TextBlock Text="{Binding StatusText}" FontSize="10.5" Foreground="{StaticResource Text3Brush}"/></StackPanel>
                        </StackPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,12,8,0">
                        <StackPanel>
                            <TextBlock Text="LIBRARY" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource Text4Brush}" Margin="12,4,0,7"/>
                            <Button Content="Gallery" Click="Nav_Click" Tag="Gallery"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Gallery"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Search" Click="Nav_Click" Tag="Search"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Search"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Albums" Click="Nav_Click" Tag="Albums"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Albums"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="People" Click="Nav_Click" Tag="People"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="People"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Map" Click="Nav_Click" Tag="Map"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Map"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Trips" Click="Nav_Click" Tag="Trips"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Trips"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>

                            <TextBlock Text="TOOLS" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource Text4Brush}" Margin="12,18,0,7"/>
                            <Button Content="Scan Center" Click="Nav_Click" Tag="Scan Center"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Scan Center"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Health" Click="Nav_Click" Tag="Health"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Health"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Insights" Click="Nav_Click" Tag="Insights"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Insights"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Cleanup" Click="Nav_Click" Tag="Cleanup"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Cleanup"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>

                            <TextBlock Text="SECURITY" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource Text4Brush}" Margin="12,18,0,7"/>
                            <Button Content="Vault" Click="Nav_Click" Tag="Vault"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Vault"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>

                            <TextBlock Text="SYSTEM" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource Text4Brush}" Margin="12,18,0,7"/>
                            <Button Content="Plugins" Click="Nav_Click" Tag="Plugins"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Plugins"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Export" Click="Nav_Click" Tag="Export"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Export"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Backup" Click="Nav_Click" Tag="Backup"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Backup"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="Settings" Click="Nav_Click" Tag="Settings"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="Settings"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                            <Button Content="System Log" Click="Nav_Click" Tag="System Log"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Style.Triggers><DataTrigger Binding="{Binding CurrentView}" Value="System Log"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.1"/></Setter.Value></Setter><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- CONTENT -->
            <Border Grid.Column="1" Background="{StaticResource BgBrush}">
                <Grid>
                    <ctrl:GalleryView x:Name="galleryView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Gallery}"/>
                    <ctrl:SearchView x:Name="searchView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Search}"/>
                    <ctrl:AlbumsView x:Name="albumsView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Albums}"/>
                    <ctrl:ScanCenterView x:Name="scanView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Scan Center}"/>
                    <ctrl:SettingsView x:Name="settingsView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Settings}"/>
                    <ctrl:SystemLogView x:Name="logView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=System Log}"/>
                    <ctrl:HealthView x:Name="healthView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Health}"/>
                    <ctrl:InsightsView x:Name="insightsView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Insights}"/>
                    <ctrl:CleanupView x:Name="cleanupView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Cleanup}"/>
                    <ctrl:TripsView x:Name="tripsView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Trips}"/>
                    <ctrl:MapView x:Name="mapView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Map}"/>
                    <ctrl:VaultView x:Name="vaultView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Vault}"/>
                    <ctrl:ExportView x:Name="exportView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Export}"/>
                    <ctrl:BackupView x:Name="backupView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Backup}"/>
                    <ctrl:PluginsView x:Name="pluginsView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=Plugins}"/>
                    <ctrl:PeopleView x:Name="peopleView" Visibility="{Binding DataContext.CurrentView, ElementName=mainWin, Converter={StaticResource StrVis}, ConverterParameter=People}"/>

                    <!-- VIEWER OVERLAY -->
                    <Grid Background="#000" Visibility="{Binding DataContext.GalleryVm.Viewer.IsOpen, ElementName=mainWin, Converter={StaticResource BoolVis}}" Panel.ZIndex="50">
                        <!-- Top bar -->
                        <DockPanel VerticalAlignment="Top" Height="46" Background="{StaticResource SidebarBrush}" Panel.ZIndex="10">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.GalleryVm.Viewer.FileName, ElementName=mainWin}" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="{Binding DataContext.GalleryVm.Viewer.PositionText, ElementName=mainWin}" FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="14,0,0,0"/>
                                <!-- Stars -->
                                <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                                    <Button Content="{Binding DataContext.GalleryVm.Viewer.Star1, ElementName=mainWin}" Style="{StaticResource BtnGhost}" Padding="2,4" FontSize="16" Command="{Binding DataContext.GalleryVm.Viewer.SetRatingCommand, ElementName=mainWin}" CommandParameter="1"/>
                                    <Button Content="{Binding DataContext.GalleryVm.Viewer.Star2, ElementName=mainWin}" Style="{StaticResource BtnGhost}" Padding="2,4" FontSize="16" Command="{Binding DataContext.GalleryVm.Viewer.SetRatingCommand, ElementName=mainWin}" CommandParameter="2"/>
                                    <Button Content="{Binding DataContext.GalleryVm.Viewer.Star3, ElementName=mainWin}" Style="{StaticResource BtnGhost}" Padding="2,4" FontSize="16" Command="{Binding DataContext.GalleryVm.Viewer.SetRatingCommand, ElementName=mainWin}" CommandParameter="3"/>
                                    <Button Content="{Binding DataContext.GalleryVm.Viewer.Star4, ElementName=mainWin}" Style="{StaticResource BtnGhost}" Padding="2,4" FontSize="16" Command="{Binding DataContext.GalleryVm.Viewer.SetRatingCommand, ElementName=mainWin}" CommandParameter="4"/>
                                    <Button Content="{Binding DataContext.GalleryVm.Viewer.Star5, ElementName=mainWin}" Style="{StaticResource BtnGhost}" Padding="2,4" FontSize="16" Command="{Binding DataContext.GalleryVm.Viewer.SetRatingCommand, ElementName=mainWin}" CommandParameter="5"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Button Content="&#x2665;" Style="{StaticResource BtnGhost}" Padding="8,5" FontSize="14" Margin="3,0" Command="{Binding DataContext.GalleryVm.Viewer.ToggleFavoriteCommand, ElementName=mainWin}" ToolTip="Favorite"/>
                                <Button Content="Vault" Style="{StaticResource BtnGhost}" Padding="8,5" FontSize="11" Margin="3,0" Command="{Binding DataContext.GalleryVm.Viewer.MoveToVaultCommand, ElementName=mainWin}" ToolTip="Move to Vault"/>
                                <Button Content="Edit" Style="{StaticResource Btn}" Padding="12,5" Margin="3,0" Command="{Binding DataContext.GalleryVm.Viewer.ToggleEditPanelCommand, ElementName=mainWin}"/>
                                <Button Content="Info" Style="{StaticResource Btn}" Padding="12,5" Margin="3,0" Command="{Binding DataContext.GalleryVm.Viewer.ToggleInfoPanelCommand, ElementName=mainWin}"/>
                                <Button Content="Close" Style="{StaticResource BtnDanger}" Padding="12,5" Margin="3,0" Command="{Binding DataContext.GalleryVm.Viewer.CloseCommand, ElementName=mainWin}"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Nav arrows -->
                        <Button Content="&#x276E;" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0" Style="{StaticResource Btn}" Padding="12,10" Command="{Binding DataContext.GalleryVm.Viewer.PreviousCommand, ElementName=mainWin}" Panel.ZIndex="10"/>
                        <Button Content="&#x276F;" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="12,0" Style="{StaticResource Btn}" Padding="12,10" Command="{Binding DataContext.GalleryVm.Viewer.NextCommand, ElementName=mainWin}" Panel.ZIndex="10"/>

                        <!-- Image -->
                        <Image Source="{Binding DataContext.GalleryVm.Viewer.CurrentImage, ElementName=mainWin}" Stretch="Uniform" Margin="50,50,50,36" RenderOptions.BitmapScalingMode="HighQuality" Visibility="{Binding DataContext.GalleryVm.Viewer.IsVideo, ElementName=mainWin, Converter={StaticResource InvVis}}" MouseLeftButtonDown="Viewer_DoubleClick"/>

                        <!-- Video -->
                        <MediaElement x:Name="videoPlayer" Stretch="Uniform" Margin="50,50,50,90" LoadedBehavior="Manual" UnloadedBehavior="Stop" Visibility="{Binding DataContext.GalleryVm.Viewer.IsVideo, ElementName=mainWin, Converter={StaticResource BoolVis}}" MediaOpened="Video_Opened" MouseLeftButtonDown="Viewer_DoubleClick"/>

                        <!-- Video controls -->
                        <Border VerticalAlignment="Bottom" Margin="0" Visibility="{Binding DataContext.GalleryVm.Viewer.IsVideo, ElementName=mainWin, Converter={StaticResource BoolVis}}" Panel.ZIndex="10">
                            <Border Background="#E0000000" Padding="0">
                                <StackPanel>
                                    <Slider Minimum="0" Maximum="{Binding DataContext.GalleryVm.Viewer.VideoDuration, ElementName=mainWin}" Value="{Binding DataContext.GalleryVm.Viewer.VideoPosition, ElementName=mainWin, Mode=TwoWay}" Height="20" Margin="0,-6,0,0" ValueChanged="Seek_Changed"/>
                                    <DockPanel Margin="12,4,12,8">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BtnGhost}" Padding="8,6" FontSize="18" Margin="0,0,2,0" Command="{Binding DataContext.GalleryVm.Viewer.TogglePlayCommand, ElementName=mainWin}"><TextBlock Text="{Binding DataContext.GalleryVm.Viewer.PlayIcon, ElementName=mainWin}" FontSize="18"/></Button>
                                            <Button Style="{StaticResource BtnGhost}" Padding="6,6" Margin="0,0,2,0" Command="{Binding DataContext.GalleryVm.Viewer.SkipBackCommand, ElementName=mainWin}" ToolTip="Back 10s"><TextBlock Text="&#x23EA;" FontSize="14"/></Button>
                                            <Button Style="{StaticResource BtnGhost}" Padding="6,6" Margin="0,0,8,0" Command="{Binding DataContext.GalleryVm.Viewer.SkipForwardCommand, ElementName=mainWin}" ToolTip="Forward 10s"><TextBlock Text="&#x23E9;" FontSize="14"/></Button>
                                            <Button Style="{StaticResource BtnGhost}" Padding="6,6" Margin="0,0,4,0" Command="{Binding DataContext.GalleryVm.Viewer.ToggleMuteCommand, ElementName=mainWin}"><TextBlock Text="{Binding DataContext.GalleryVm.Viewer.VolumeIcon, ElementName=mainWin}" FontSize="14"/></Button>
                                            <Slider Minimum="0" Maximum="1" Width="70" VerticalAlignment="Center" Margin="0,0,10,0" Value="{Binding DataContext.GalleryVm.Viewer.VideoVolume, ElementName=mainWin}" ValueChanged="Volume_Changed"/>
                                            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Text2Brush}" FontFamily="{StaticResource MonoFont}"><Run Text="{Binding DataContext.GalleryVm.Viewer.CurrentTimeText, ElementName=mainWin, Mode=OneWay}"/><Run Text=" / " Foreground="{StaticResource Text4Brush}"/><Run Text="{Binding DataContext.GalleryVm.Viewer.TotalTimeText, ElementName=mainWin, Mode=OneWay}"/></TextBlock>
                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <ComboBox Width="60" Margin="0,0,6,0" SelectedIndex="2" SelectionChanged="Speed_Changed"><ComboBoxItem Content="0.25x" Tag="0.25"/><ComboBoxItem Content="0.5x" Tag="0.5"/><ComboBoxItem Content="1x" Tag="1"/><ComboBoxItem Content="1.5x" Tag="1.5"/><ComboBoxItem Content="2x" Tag="2"/></ComboBox>
                                            <Button Style="{StaticResource BtnGhost}" Padding="8,6" Command="{Binding DataContext.GalleryVm.Viewer.ToggleCinematicCommand, ElementName=mainWin}" ToolTip="Fullscreen"><TextBlock Text="&#x26F6;" FontSize="14"/></Button>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Photo info bottom -->
                        <TextBlock Text="{Binding DataContext.GalleryVm.Viewer.FileInfo, ElementName=mainWin}" FontSize="12" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,12" Visibility="{Binding DataContext.GalleryVm.Viewer.IsVideo, ElementName=mainWin, Converter={StaticResource InvVis}}"/>

                        <!-- Edit panel -->
                        <Border Width="260" HorizontalAlignment="Right" Margin="0,46,0,0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Visibility="{Binding DataContext.GalleryVm.Viewer.IsEditPanelOpen, ElementName=mainWin, Converter={StaticResource BoolVis}}" Panel.ZIndex="15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="18,16">
                                <StackPanel>
                                    <TextBlock Text="Edit" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                    <DockPanel Margin="0,0,0,4"><TextBlock Text="Brightness" FontSize="12" Foreground="{StaticResource Text2Brush}"/><TextBlock Text="{Binding DataContext.GalleryVm.Viewer.EditBrightness, ElementName=mainWin, StringFormat='{}{0:N0}'}" FontSize="10" Foreground="{StaticResource Text3Brush}" DockPanel.Dock="Right"/></DockPanel>
                                    <Slider Minimum="-100" Maximum="100" Value="{Binding DataContext.GalleryVm.Viewer.EditBrightness, ElementName=mainWin}" Margin="0,0,0,12"/>
                                    <DockPanel Margin="0,0,0,4"><TextBlock Text="Contrast" FontSize="12" Foreground="{StaticResource Text2Brush}"/><TextBlock Text="{Binding DataContext.GalleryVm.Viewer.EditContrast, ElementName=mainWin, StringFormat='{}{0:N0}'}" FontSize="10" Foreground="{StaticResource Text3Brush}" DockPanel.Dock="Right"/></DockPanel>
                                    <Slider Minimum="-100" Maximum="100" Value="{Binding DataContext.GalleryVm.Viewer.EditContrast, ElementName=mainWin}" Margin="0,0,0,12"/>
                                    <DockPanel Margin="0,0,0,4"><TextBlock Text="Saturation" FontSize="12" Foreground="{StaticResource Text2Brush}"/><TextBlock Text="{Binding DataContext.GalleryVm.Viewer.EditSaturation, ElementName=mainWin, StringFormat='{}{0:N0}'}" FontSize="10" Foreground="{StaticResource Text3Brush}" DockPanel.Dock="Right"/></DockPanel>
                                    <Slider Minimum="-100" Maximum="100" Value="{Binding DataContext.GalleryVm.Viewer.EditSaturation, ElementName=mainWin}" Margin="0,0,0,12"/>
                                    <Button Content="Reset All" Style="{StaticResource BtnAccent}" Margin="0,14,0,0" Padding="12,6" Command="{Binding DataContext.GalleryVm.Viewer.ResetEditsCommand, ElementName=mainWin}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Info panel -->
                        <Border Width="260" HorizontalAlignment="Right" Margin="0,46,0,0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Visibility="{Binding DataContext.GalleryVm.Viewer.IsInfoPanelOpen, ElementName=mainWin, Converter={StaticResource BoolVis}}" Panel.ZIndex="15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="18,16">
                                <StackPanel>
                                    <TextBlock Text="Metadata" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                    <ItemsControl ItemsSource="{Binding DataContext.GalleryVm.Viewer.MetadataRows, ElementName=mainWin}"><ItemsControl.ItemTemplate><DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,6"><DockPanel><TextBlock Text="{Binding Key}" FontSize="11.5" Foreground="{StaticResource Text3Brush}" Width="85"/><TextBlock Text="{Binding Value}" FontSize="11.5" TextTrimming="CharacterEllipsis" DockPanel.Dock="Right" HorizontalAlignment="Right" MaxWidth="145"/></DockPanel></Border>
                                    </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
