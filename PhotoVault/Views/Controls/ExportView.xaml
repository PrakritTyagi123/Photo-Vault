<UserControl x:Class="PhotoVault.Views.Controls.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Export" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16" Margin="0,0,0,14">
                <StackPanel><TextBlock Text="Export Album" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/><TextBlock Text="Select an album from the Albums page, then export." FontSize="12" Foreground="{StaticResource Text3Brush}"/><TextBlock Text="Formats: Copy to folder, ZIP archive" FontSize="11" Foreground="{StaticResource Text4Brush}" Margin="0,8,0,0"/></StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16">
                <StackPanel><TextBlock Text="Export All" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/><TextBlock Text="Export entire library organized by date." FontSize="12" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,12"/>
                <Button Content="Export All to Folder" Style="{StaticResource BtnAccent}" Padding="16,8" Command="{Binding ExportAllCommand}"/><TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0"/></StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
