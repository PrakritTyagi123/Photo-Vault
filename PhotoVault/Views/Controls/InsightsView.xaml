<UserControl x:Class="PhotoVault.Views.Controls.InsightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="Insights" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>
            <WrapPanel Margin="0,0,0,18">
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,10,10" MinWidth="140"><StackPanel><TextBlock Text="{Binding GpsCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="GPS Tagged" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel></Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,10,10" MinWidth="140"><StackPanel><TextBlock Text="{Binding FavoriteCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource RedBrush}"/><TextBlock Text="Favorites" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel></Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,10,10" MinWidth="140"><StackPanel><TextBlock Text="{Binding AvgQuality, StringFormat='{}{0:N0}'}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/><TextBlock Text="Avg Quality" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel></Border>
            </WrapPanel>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16" Margin="0,0,0,14"><StackPanel><TextBlock Text="Top Cameras" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding TopCameras}"><ItemsControl.ItemTemplate><DataTemplate><DockPanel Margin="0,0,0,6"><TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="{StaticResource Text2Brush}"/><TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontSize="12.5" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" FontWeight="SemiBold"/></DockPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16" Margin="0,0,0,14"><StackPanel><TextBlock Text="Top Locations" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding TopLocations}"><ItemsControl.ItemTemplate><DataTemplate><DockPanel Margin="0,0,0,6"><TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="{StaticResource Text2Brush}"/><TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontSize="12.5" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" FontWeight="SemiBold"/></DockPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16"><StackPanel><TextBlock Text="Storage Breakdown" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding StorageBreakdown}"><ItemsControl.ItemTemplate><DataTemplate><DockPanel Margin="0,0,0,6"><TextBlock Text="{Binding Type}" FontSize="12.5" Foreground="{StaticResource Text2Brush}" Width="80"/><TextBlock Text="{Binding Count, StringFormat='{}{0} files'}" FontSize="12" Foreground="{StaticResource Text3Brush}" Width="80"/><TextBlock DockPanel.Dock="Right" Text="{Binding SizeDisplay}" FontSize="12" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" FontWeight="Medium"/></DockPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
