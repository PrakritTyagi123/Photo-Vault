<UserControl x:Class="PhotoVault.Views.Controls.AlbumsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoVault.Views">
    <UserControl.Resources>
        <local:PathToThumbnailConverter x:Key="PathToThumb"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvVis"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,28">
                <StackPanel Visibility="{Binding IsViewingAlbum, Converter={StaticResource InvVis}}">
                    <DockPanel Margin="0,0,0,20"><TextBlock Text="Albums" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/><Button DockPanel.Dock="Right" Content="+ New Album" Style="{StaticResource BtnAccent}" Padding="16,8" HorizontalAlignment="Right" Command="{Binding ShowCreateDialogCommand}"/></DockPanel>
                    <TextBlock Text="Smart Albums" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding SmartAlbums}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <Border Width="195" Margin="0,0,10,10" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Cursor="Hand" MouseLeftButtonDown="Album_Click">
                                <StackPanel><Border Height="100" CornerRadius="8,8,0,0" ClipToBounds="True" Background="{StaticResource SurfaceHoverBrush}"><Image Source="{Binding CoverPath, Converter={StaticResource PathToThumb}, ConverterParameter=200}" Stretch="UniformToFill"/></Border>
                                <StackPanel Margin="12,9,12,11"><TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"/><TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,3,0,0"/></StackPanel></StackPanel>
                            </Border>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="My Albums" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Text2Brush}" Margin="0,20,0,10"/>
                    <ItemsControl ItemsSource="{Binding ManualAlbums}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <Border Width="195" Margin="0,0,10,10" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Cursor="Hand" MouseLeftButtonDown="Album_Click">
                                <StackPanel><Border Height="100" CornerRadius="8,8,0,0" ClipToBounds="True" Background="{StaticResource SurfaceHoverBrush}"><Image Source="{Binding CoverPath, Converter={StaticResource PathToThumb}, ConverterParameter=200}" Stretch="UniformToFill"/></Border>
                                <StackPanel Margin="12,9,12,11"><DockPanel><TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"/><Button DockPanel.Dock="Right" Content="&#x2715;" Style="{StaticResource BtnDanger}" Padding="5,2" FontSize="9" HorizontalAlignment="Right" Click="DeleteAlbum_Click"/></DockPanel>
                                <TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,3,0,0"/></StackPanel></StackPanel>
                            </Border>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Visibility="{Binding IsViewingAlbum, Converter={StaticResource BoolVis}}">
                    <DockPanel Margin="0,0,0,18"><StackPanel Orientation="Horizontal"><Button Content="Back" Style="{StaticResource Btn}" Padding="14,7" Margin="0,0,14,0" Command="{Binding CloseAlbumCommand}"/><TextBlock Text="{Binding CurrentAlbumName}" FontSize="24" FontWeight="Bold"/><Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="12,3" Margin="14,0,0,0" VerticalAlignment="Center"><TextBlock Text="{Binding CurrentAlbumCount, StringFormat='{}{0} items'}" FontSize="11" Foreground="{StaticResource Text2Brush}"/></Border></StackPanel></DockPanel>
                    <ItemsControl ItemsSource="{Binding CurrentAlbumMedia}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <Border Width="156" Height="156" Margin="3" CornerRadius="6" Background="{StaticResource SurfaceBrush}" Cursor="Hand" ClipToBounds="True" MouseLeftButtonDown="AlbumPhoto_Click" BorderBrush="Transparent" BorderThickness="2">
                                <Border.Style><Style TargetType="Border"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/></Trigger></Style.Triggers></Style></Border.Style>
                                <Image Source="{Binding ThumbnailSmall, Converter={StaticResource PathToThumb}, ConverterParameter=160}" Stretch="UniformToFill"/>
                            </Border>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <Grid Background="#60000000" Visibility="{Binding IsCreateDialogOpen, Converter={StaticResource BoolVis}}">
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="28" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel><TextBlock Text="Create Album" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/><TextBox Text="{Binding NewAlbumName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button Content="Cancel" Style="{StaticResource Btn}" Padding="16,8" Margin="0,0,8,0" Command="{Binding CancelCreateCommand}"/><Button Content="Create" Style="{StaticResource BtnAccent}" Padding="16,8" Command="{Binding ConfirmCreateCommand}"/></StackPanel></StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
