<UserControl x:Class="PhotoVault.Views.Controls.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Backup" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16" Margin="0,0,0,14">
                <StackPanel><TextBlock Text="Create Backup" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/><TextBlock Text="Database + thumbnails as zip" FontSize="12" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,12"/>
                <Button Content="Create Backup" Style="{StaticResource BtnAccent}" Padding="16,8" Command="{Binding CreateBackupCommand}"/><TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0"/></StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16">
                <StackPanel><TextBlock Text="Existing Backups" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Backups}"><ItemsControl.ItemTemplate><DataTemplate>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8"><StackPanel><TextBlock Text="{Binding FileName}" FontSize="12" FontFamily="{StaticResource MonoFont}"/><TextBlock FontSize="10.5" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0"><Run Text="{Binding DateDisplay, Mode=OneWay}"/><Run Text="  —  "/><Run Text="{Binding SizeDisplay, Mode=OneWay}"/></TextBlock></StackPanel></Border>
                </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                <TextBlock Text="No backups yet" Foreground="{StaticResource Text4Brush}" FontSize="12" Margin="0,8,0,0">
                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppFont}"/><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Backups.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock></StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
