<UserControl x:Class="PhotoVault.Views.Controls.VaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoVault.Views">
    <UserControl.Resources><BooleanToVisibilityConverter x:Key="BoolVis"/><local:InverseBoolToVisibilityConverter x:Key="InvVis"/></UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Vault" FontSize="24" FontWeight="Bold" Margin="0,0,0,6"/><TextBlock Text="AES-256 encrypted storage for private photos" FontSize="12" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,22"/>
            <StackPanel Visibility="{Binding IsUnlocked, Converter={StaticResource InvVis}}">
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="24" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Width="300">
                        <TextBlock Text="Enter Vault Password" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <PasswordBox x:Name="pwdBox" FontSize="14" Padding="10,8" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Unlock" Style="{StaticResource BtnAccent}" Padding="20,8" Margin="0,0,8,0" Click="Unlock_Click"/>
                            <Button Content="Set Password" Style="{StaticResource Btn}" Padding="14,8" Click="SetPwd_Click" Visibility="{Binding NeedsPassword, Converter={StaticResource BoolVis}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ErrorText}" Foreground="{StaticResource RedBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel Visibility="{Binding IsUnlocked, Converter={StaticResource BoolVis}}">
                <DockPanel Margin="0,0,0,16"><TextBlock Text="{Binding VaultedCount, StringFormat='{}{0} items in vault'}" FontSize="14" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/><Button DockPanel.Dock="Right" Content="Lock" Style="{StaticResource BtnDanger}" Padding="14,7" HorizontalAlignment="Right" Command="{Binding LockCommand}"/></DockPanel>
                <ItemsControl ItemsSource="{Binding VaultedItems}"><ItemsControl.ItemTemplate><DataTemplate>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="10,7" Margin="0,1"><DockPanel><TextBlock Text="{Binding FileName}" FontSize="12.5" VerticalAlignment="Center"/><TextBlock DockPanel.Dock="Right" Text="{Binding FileSizeDisplay}" FontSize="11" Foreground="{StaticResource Text3Brush}" VerticalAlignment="Center" HorizontalAlignment="Right"/></DockPanel></Border>
                </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                <TextBlock Text="Vault is empty" Foreground="{StaticResource Text4Brush}" FontSize="13" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppFont}"/><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding VaultedCount}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
