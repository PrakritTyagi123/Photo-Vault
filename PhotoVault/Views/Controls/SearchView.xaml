<UserControl x:Class="PhotoVault.Views.Controls.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoVault.Views">
    <UserControl.Resources>
        <local:PathToThumbnailConverter x:Key="PathToThumb"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvVis"/>
        <local:IsVideoToVisibilityConverter x:Key="VidVis"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="Search" FontSize="24" FontWeight="Bold" Margin="0,0,0,18"/>
            <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14,0" Margin="0,0,0,14">
                <DockPanel>
                    <TextBlock Text="&#x1F50D;" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource Text4Brush}"/>
                    <Button DockPanel.Dock="Right" Content="Clear" Style="{StaticResource BtnGhost}" Padding="10,6" FontSize="11" Command="{Binding ClearFiltersCommand}" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Padding="0,11" VerticalAlignment="Center" TextChanged="Search_Changed"/>
                </DockPanel>
            </Border>
            <WrapPanel Margin="0,0,0,12">
                <ComboBox Width="108" Margin="0,0,6,6" SelectedIndex="0" SelectionChanged="Filter_Changed" Tag="month">
                    <ComboBoxItem Content="Month" Tag=""/><ComboBoxItem Content="January" Tag="January"/><ComboBoxItem Content="February" Tag="February"/><ComboBoxItem Content="March" Tag="March"/><ComboBoxItem Content="April" Tag="April"/><ComboBoxItem Content="May" Tag="May"/><ComboBoxItem Content="June" Tag="June"/><ComboBoxItem Content="July" Tag="July"/><ComboBoxItem Content="August" Tag="August"/><ComboBoxItem Content="September" Tag="September"/><ComboBoxItem Content="October" Tag="October"/><ComboBoxItem Content="November" Tag="November"/><ComboBoxItem Content="December" Tag="December"/>
                </ComboBox>
                <ComboBox x:Name="cbLoc" Width="108" Margin="0,0,6,6" SelectionChanged="Filter_Changed" Tag="location"/>
                <ComboBox x:Name="cbCam" Width="135" Margin="0,0,6,6" SelectionChanged="Filter_Changed" Tag="camera"/>
                <ComboBox x:Name="cbType" Width="95" Margin="0,0,6,6" SelectionChanged="Filter_Changed" Tag="type"/>
                <ComboBox x:Name="cbLens" Width="125" Margin="0,0,6,6" SelectionChanged="Filter_Changed" Tag="lens"/>
                <ComboBox x:Name="cbVibe" Width="95" Margin="0,0,6,6" SelectionChanged="Filter_Changed" Tag="vibe"/>
            </WrapPanel>
            <WrapPanel Margin="0,0,0,18">
                <ItemsControl ItemsSource="{Binding Suggestions}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate><DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12,5" Margin="0,0,6,6" Cursor="Hand" MouseLeftButtonDown="Chip_Click">
                            <TextBlock Text="{Binding}" FontSize="11.5" Foreground="{StaticResource Text2Brush}"/>
                        </Border>
                    </DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
            <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="{StaticResource Text2Brush}" FontWeight="Medium" Margin="0,0,0,12" Visibility="{Binding HasSearched, Converter={StaticResource BoolVis}}"/>
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate><DataTemplate>
                    <Border Width="156" Height="156" Margin="3" CornerRadius="6" Background="{StaticResource SurfaceBrush}" Cursor="Hand" ClipToBounds="True" MouseLeftButtonDown="Result_Click" BorderBrush="Transparent" BorderThickness="2">
                        <Border.Style><Style TargetType="Border"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/></Trigger></Style.Triggers></Style></Border.Style>
                        <Grid>
                            <Image Source="{Binding ThumbnailSmall, Converter={StaticResource PathToThumb}, ConverterParameter=160}" Stretch="UniformToFill"/>
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding MediaType, Converter={StaticResource VidVis}}" Width="32" Height="32" CornerRadius="16">
                                <Border.Background><SolidColorBrush Color="#000" Opacity="0.5"/></Border.Background>
                                <TextBlock Text="&#x25B6;" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate></ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="Enter a query or select filters" Foreground="{StaticResource Text3Brush}" FontSize="14" Margin="0,60,0,0" HorizontalAlignment="Center" Visibility="{Binding HasSearched, Converter={StaticResource InvVis}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
