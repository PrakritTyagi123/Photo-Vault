<UserControl x:Class="PhotoVault.Views.Controls.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoVault.Views">
    <UserControl.Resources>
        <local:PathToThumbnailConverter x:Key="PathToThumb"/>
        <local:FormatBadgeVisibilityConverter x:Key="FmtVis"/>
        <local:ExtensionToLabelConverter x:Key="ExtLbl"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvVis"/>
        <local:StringEqualsToVisibilityConverter x:Key="StrVis"/>
        <local:IsVideoToVisibilityConverter x:Key="VidVis"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,28">
                <DockPanel Margin="0,0,0,18">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Gallery" FontSize="24" FontWeight="Bold"/>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="12,3" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} items'}" FontSize="11" Foreground="{StaticResource Text2Brush}"/>
                        </Border>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Grid" Padding="12,6" FontSize="11.5" Command="{Binding SetViewModeCommand}" CommandParameter="grid" Style="{StaticResource BtnGhost}"/>
                                <Button Content="List" Padding="12,6" FontSize="11.5" Command="{Binding SetViewModeCommand}" CommandParameter="list" Style="{StaticResource BtnGhost}"/>
                            </StackPanel>
                        </Border>
                        <ComboBox Width="110" SelectedIndex="0" SelectionChanged="Sort_Changed">
                            <ComboBoxItem Content="Newest" Tag="date-desc"/><ComboBoxItem Content="Oldest" Tag="date-asc"/>
                            <ComboBoxItem Content="Name" Tag="name"/><ComboBoxItem Content="Size" Tag="size"/>
                        </ComboBox>
                    </StackPanel>
                </DockPanel>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="14,9" Margin="0,0,0,14" Visibility="{Binding IsScanning, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding ScanStatus}" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                </Border>
                <ItemsControl ItemsSource="{Binding GroupedItems}">
                    <ItemsControl.GroupStyle><GroupStyle><GroupStyle.HeaderTemplate><DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,20,0,8" Margin="0,0,0,6">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Text2Brush}"><Run Text="{Binding Name, Mode=OneWay}"/><Run Text="{Binding ItemCount, Mode=OneWay, StringFormat=' ({0})'}" Foreground="{StaticResource Text3Brush}" FontWeight="Normal" FontSize="12"/></TextBlock>
                        </Border>
                    </DataTemplate></GroupStyle.HeaderTemplate></GroupStyle></ItemsControl.GroupStyle>
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate><DataTemplate>
                        <Border Width="156" Height="156" Margin="3" CornerRadius="6" ClipToBounds="True" Cursor="Hand" Background="{StaticResource SurfaceBrush}" MouseLeftButtonDown="Card_Click" BorderBrush="Transparent" BorderThickness="2">
                            <Border.Style><Style TargetType="Border"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/></Trigger></Style.Triggers></Style></Border.Style>
                            <Grid>
                                <Image Source="{Binding ThumbnailSmall, Converter={StaticResource PathToThumb}, ConverterParameter=160}" Stretch="UniformToFill"/>
                                <Border Visibility="{Binding HasThumbnail, Converter={StaticResource InvVis}}" Background="{StaticResource SurfaceHoverBrush}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding FileExtension, Converter={StaticResource ExtLbl}}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileSizeDisplay}" FontSize="9" Foreground="{StaticResource Text4Brush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6" Padding="5,2" CornerRadius="4" Visibility="{Binding FileExtension, Converter={StaticResource FmtVis}}">
                                    <Border.Background><SolidColorBrush Color="#000" Opacity="0.55"/></Border.Background>
                                    <TextBlock Text="{Binding FileExtension, Converter={StaticResource ExtLbl}}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Text2Brush}"/>
                                </Border>
                                <Border HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding MediaType, Converter={StaticResource VidVis}}" Width="32" Height="32" CornerRadius="16">
                                    <Border.Background><SolidColorBrush Color="#000" Opacity="0.5"/></Border.Background>
                                    <TextBlock Text="&#x25B6;" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel HorizontalAlignment="Center" Margin="0,80,0,0">
                    <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding TotalCount}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                    <TextBlock Text="No media in library" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Go to Settings to add watched folders" FontSize="12" Foreground="{StaticResource Text4Brush}" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button Content="Open Settings" Style="{StaticResource BtnAccent}" Padding="18,9" FontSize="13" HorizontalAlignment="Center" Click="GoToSettings_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
