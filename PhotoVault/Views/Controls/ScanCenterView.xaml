<UserControl x:Class="PhotoVault.Views.Controls.ScanCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoVault.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <local:PercentToWidthConverter x:Key="PctWidth"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <DockPanel Margin="0,0,0,8"><TextBlock Text="Scan Center" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Pause" Style="{StaticResource Btn}" Padding="12,7" Margin="0,0,6,0" Command="{Binding PauseCommand}" Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                    <Button Content="Cancel" Style="{StaticResource BtnDanger}" Padding="12,7" Margin="0,0,6,0" Command="{Binding CancelCommand}" Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                    <Button Content="Run All Scans" Style="{StaticResource BtnAccent}" Padding="16,8" Command="{Binding RunAllCommand}"/>
                </StackPanel>
            </DockPanel>
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="14,9" Margin="0,0,0,16"><TextBlock Text="{Binding StatusText}" FontSize="12.5" Foreground="{StaticResource AccentBrush}"/></Border>
            <ItemsControl ItemsSource="{Binding Steps}"><ItemsControl.ItemTemplate><DataTemplate>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,6">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <Border Grid.Column="0" Grid.RowSpan="2" Width="30" Height="30" CornerRadius="15" VerticalAlignment="Top" Background="{StaticResource SurfaceActiveBrush}">
                            <TextBlock Text="{Binding StepNumber}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5" FontWeight="Bold" Foreground="{StaticResource Text3Brush}"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="Medium"/>
                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding NeedsAi}" Value="True"><Setter Property="Visibility" Value="Visible"/><Setter Property="Background"><Setter.Value><SolidColorBrush Color="{StaticResource OrangeColor}" Opacity="0.15"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                                    <TextBlock Text="AI Required" FontSize="9" Foreground="{StaticResource OrangeBrush}" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding LastRun, StringFormat='Last: {0}'}" FontSize="9.5" Foreground="{StaticResource GreenBrush}" Margin="0,4,0,0">
                                <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppFont}"/><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding LastRun}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Padding="12,6" FontSize="11" VerticalAlignment="Top" Click="RunStep_Click" Tag="{Binding Id}">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource Btn}"><Setter Property="Content" Value="Start"/><Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Content" Value="Re-run"/></DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Content" Value="Running..."/><Setter Property="IsEnabled" Value="False"/></DataTrigger>
                                <DataTrigger Binding="{Binding IsImplemented}" Value="False"><Setter Property="IsEnabled" Value="False"/><Setter Property="Content" Value="N/A"/></DataTrigger>
                            </Style.Triggers></Style></Button.Style>
                        </Button>
                        <Grid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Margin="10,8,0,0">
                            <Border Height="4" CornerRadius="2" Background="{StaticResource SurfaceActiveBrush}"/>
                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}" Width="{Binding Progress, Converter={StaticResource PctWidth}}"/>
                            <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}" FontSize="9.5" Foreground="{StaticResource Text4Brush}" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
