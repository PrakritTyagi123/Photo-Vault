<UserControl x:Class="PhotoVault.Views.Controls.TripsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <DockPanel Margin="0,0,0,22"><TextBlock Text="Trips" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/><Button DockPanel.Dock="Right" Content="Detect Trips" Style="{StaticResource BtnAccent}" Padding="14,7" HorizontalAlignment="Right" Command="{Binding DetectCommand}"/></DockPanel>
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,14"/>
            <ItemsControl ItemsSource="{Binding Trips2}"><ItemsControl.ItemTemplate><DataTemplate>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,0,8">
                    <DockPanel><StackPanel><TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/><TextBlock Text="{Binding DateRange}" FontSize="11.5" Foreground="{StaticResource Text2Brush}" Margin="0,3,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="{Binding City}" FontSize="11" Foreground="{StaticResource Text3Brush}"/><TextBlock Text=", " FontSize="11" Foreground="{StaticResource Text4Brush}"/><TextBlock Text="{Binding Country}" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel>
                    </StackPanel><TextBlock DockPanel.Dock="Right" Text="{Binding PhotoCount, StringFormat='{}{0} photos'}" FontSize="13" Foreground="{StaticResource AccentBrush}" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center"/></DockPanel>
                </Border>
            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
            <TextBlock Text="No trips detected. Click Detect Trips to analyze GPS data." Foreground="{StaticResource Text4Brush}" FontSize="13" Margin="0,30,0,0" HorizontalAlignment="Center">
                <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppFont}"/><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Trips2.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
