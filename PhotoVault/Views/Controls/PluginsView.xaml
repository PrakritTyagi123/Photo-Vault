<UserControl x:Class="PhotoVault.Views.Controls.PluginsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Plugins" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16" Margin="0,0,0,14">
                <StackPanel><DockPanel Margin="0,0,0,12"><TextBlock Text="Installed Plugins" FontSize="15" FontWeight="SemiBold"/><Button DockPanel.Dock="Right" Content="Open Folder" Style="{StaticResource Btn}" Padding="12,6" HorizontalAlignment="Right" Command="{Binding OpenFolderCommand}"/></DockPanel>
                <ItemsControl ItemsSource="{Binding Plugins2}"><ItemsControl.ItemTemplate><DataTemplate>
                    <Border Background="{StaticResource SurfaceHoverBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,6"><StackPanel>
                        <TextBlock FontSize="13" FontWeight="Medium"><Run Text="{Binding Name, Mode=OneWay}"/><Run Text="{Binding Version, Mode=OneWay, StringFormat=' v{0}'}" Foreground="{StaticResource Text3Brush}" FontSize="11"/></TextBlock>
                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0"/><TextBlock Text="{Binding Author, StringFormat='by {0}'}" FontSize="10" Foreground="{StaticResource Text4Brush}" Margin="0,2,0,0"/>
                    </StackPanel></Border>
                </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                <TextBlock Text="No plugins. Drop .dll files in the plugins folder." Foreground="{StaticResource Text4Brush}" FontSize="12" Margin="0,8,0,0">
                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppFont}"/><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Plugins2.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock></StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16">
                <StackPanel><TextBlock Text="Plugin Directory" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/><TextBlock Text="{Binding PluginPath}" FontFamily="{StaticResource MonoFont}" FontSize="11.5" Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap"/></StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
