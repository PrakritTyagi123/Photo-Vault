<UserControl x:Class="PhotoVault.Views.Controls.PeopleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="28,24,28,28">
        <TextBlock Text="People" FontSize="24" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,22"/>
        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="24" HorizontalAlignment="Center" Margin="0,40,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Face Detection" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="1. Go to Settings and start the AI server" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,4"/>
                <TextBlock Text="2. Go to Scan Center and run Face Detection" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,4"/>
                <TextBlock Text="3. Detected faces will appear here grouped by person" FontSize="12" Foreground="{StaticResource Text2Brush}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
