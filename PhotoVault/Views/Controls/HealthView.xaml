<UserControl x:Class="PhotoVault.Views.Controls.HealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources><BooleanToVisibilityConverter x:Key="BoolVis"/></UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="Library Health" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,14">
                <DockPanel><StackPanel><TextBlock Text="Health Score" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding HealthScore}" FontSize="42" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="%" FontSize="20" Foreground="{StaticResource Text3Brush}" VerticalAlignment="Bottom" Margin="2,0,0,8"/></StackPanel></StackPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"><TextBlock Text="{Binding TotalItems, StringFormat='{}{0} total items'}" FontSize="13" Foreground="{StaticResource Text2Brush}"/><TextBlock Text="{Binding BrokenFiles, StringFormat='{}{0} broken files'}" FontSize="12" Foreground="{StaticResource RedBrush}" Margin="0,4,0,0"/><Button Content="Remove Broken" Style="{StaticResource BtnDanger}" Padding="10,5" FontSize="11" Margin="0,8,0,0" Command="{Binding RemoveBrokenCommand}" Visibility="{Binding HasBrokenFiles, Converter={StaticResource BoolVis}}"/></StackPanel></DockPanel>
            </Border>
            <ItemsControl ItemsSource="{Binding HealthItems}"><ItemsControl.ItemTemplate><DataTemplate>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,12" Margin="0,0,0,4">
                    <DockPanel><StackPanel><TextBlock Text="{Binding Label}" FontSize="13" FontWeight="Medium"/><TextBlock Text="{Binding Description}" FontSize="10.5" Foreground="{StaticResource Text3Brush}" Margin="0,2,0,0"/></StackPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding MissingCount, StringFormat='{}{0} missing'}" FontSize="12" Foreground="{StaticResource OrangeBrush}" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppFont}"/><Style.Triggers><DataTrigger Binding="{Binding MissingCount}" Value="0"><Setter Property="Foreground" Value="{StaticResource GreenBrush}"/><Setter Property="Text" Value="Complete"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock></DockPanel>
                </Border>
            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
