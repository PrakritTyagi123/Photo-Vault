<UserControl x:Class="PhotoVault.Views.Controls.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoVault.Views">
    <UserControl.Resources><local:PathToThumbnailConverter x:Key="PathToThumb"/></UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="Cleanup" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>
            <WrapPanel Margin="0,0,0,18">
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,10,10" MinWidth="160"><StackPanel><TextBlock Text="{Binding DuplicateCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource OrangeBrush}"/><TextBlock Text="Duplicates" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel></Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,10,10" MinWidth="160"><StackPanel><TextBlock Text="{Binding LargeFileCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PurpleBrush}"/><TextBlock Text="Large Files (50MB+)" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel></Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,10,10" MinWidth="160"><StackPanel><TextBlock Text="{Binding LowQualityCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource RedBrush}"/><TextBlock Text="Low Quality" FontSize="11" Foreground="{StaticResource Text3Brush}"/></StackPanel></Border>
            </WrapPanel>
            <TextBlock Text="Duplicate Files" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Duplicates}"><ItemsControl.ItemTemplate><DataTemplate>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,6"><StackPanel>
                    <TextBlock FontSize="11" Foreground="{StaticResource Text3Brush}" Margin="0,0,0,6"><Run Text="{Binding Count, Mode=OneWay}"/><Run Text=" copies — "/><Run Text="{Binding WastedSizeDisplay, Mode=OneWay}" Foreground="{StaticResource OrangeBrush}"/><Run Text=" wasted"/></TextBlock>
                    <ItemsControl ItemsSource="{Binding Items}"><ItemsControl.ItemTemplate><DataTemplate><DockPanel Margin="0,2">
                        <Border Width="32" Height="32" CornerRadius="4" ClipToBounds="True" Margin="0,0,8,0" Background="{StaticResource SurfaceHoverBrush}"><Image Source="{Binding ThumbnailSmall, Converter={StaticResource PathToThumb}, ConverterParameter=36}" Stretch="UniformToFill"/></Border>
                        <TextBlock Text="{Binding FileName}" FontSize="11.5" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding FileSizeDisplay}" FontSize="11" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </StackPanel></Border>
            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
            <TextBlock Text="Large Files" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>
            <ItemsControl ItemsSource="{Binding LargeFiles}"><ItemsControl.ItemTemplate><DataTemplate>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="10,7" Margin="0,1"><DockPanel>
                    <Border Width="36" Height="36" CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0" Background="{StaticResource SurfaceHoverBrush}"><Image Source="{Binding ThumbnailSmall, Converter={StaticResource PathToThumb}, ConverterParameter=40}" Stretch="UniformToFill"/></Border>
                    <TextBlock Text="{Binding FileName}" FontSize="12" VerticalAlignment="Center" Width="250"/><TextBlock Text="{Binding FileSizeDisplay}" FontSize="12" Foreground="{StaticResource PurpleBrush}" VerticalAlignment="Center" FontWeight="Medium"/>
                </DockPanel></Border>
            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
