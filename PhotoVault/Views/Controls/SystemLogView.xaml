<UserControl x:Class="PhotoVault.Views.Controls.SystemLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,28"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,16"><TextBlock Text="System Log" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox Width="90" Margin="0,0,8,0" SelectedIndex="0" SelectionChanged="Level_Changed"><ComboBoxItem Content="All" Tag="All"/><ComboBoxItem Content="Info" Tag="INFO"/><ComboBoxItem Content="Warn" Tag="WARN"/><ComboBoxItem Content="Error" Tag="ERROR"/><ComboBoxItem Content="Debug" Tag="DEBUG"/></ComboBox>
                <Button Content="Clear" Style="{StaticResource Btn}" Padding="12,6" Command="{Binding ClearCommand}"/>
            </StackPanel>
        </DockPanel>
        <Border Grid.Row="1" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding Entries}"><ItemsControl.ItemTemplate><DataTemplate>
                <DockPanel Margin="10,3">
                    <TextBlock Text="{Binding TimeString}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource Text4Brush}" Width="72"/>
                    <TextBlock Text="{Binding LevelString}" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="SemiBold" Width="42" Margin="6,0">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource MonoFont}"/><Setter Property="Foreground" Value="{StaticResource Text3Brush}"/><Style.Triggers>
                            <DataTrigger Binding="{Binding LevelString}" Value="INFO"><Setter Property="Foreground" Value="{StaticResource AccentBrush}"/></DataTrigger>
                            <DataTrigger Binding="{Binding LevelString}" Value="WARN"><Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/></DataTrigger>
                            <DataTrigger Binding="{Binding LevelString}" Value="ERROR"><Setter Property="Foreground" Value="{StaticResource RedBrush}"/></DataTrigger>
                        </Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Source}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource Text3Brush}" Width="90" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Message}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource Text2Brush}" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
        </Border>
    </Grid>
</UserControl>
